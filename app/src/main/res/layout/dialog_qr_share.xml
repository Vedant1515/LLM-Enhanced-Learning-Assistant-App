<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/colorCard"
    android:gravity="center_horizontal"
    android:paddingStart="24dp"
    android:paddingEnd="24dp"
    android:paddingTop="12dp"
    android:paddingBottom="32dp">

    <!-- Handle bar -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_marginBottom="20dp"
        android:background="@color/colorDivider" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Share Your Profile"
        android:textColor="@color/colorTextPrimary"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="6dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Scan this QR code to view profile stats"
        android:textColor="@color/colorTextMuted"
        android:textSize="13sp"
        android:layout_marginBottom="20dp" />

    <!-- QR Code container with white background padding -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:padding="12dp"
        android:layout_marginBottom="16dp">

        <ImageView
            android:id="@+id/ivQrCode"
            android:layout_width="220dp"
            android:layout_height="220dp"
            android:contentDescription="Profile QR Code"
            android:scaleType="fitCenter" />
    </LinearLayout>

    <ProgressBar
        android:id="@+id/progressQr"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginBottom="16dp"
        android:visibility="visible" />

    <!-- Profile data preview text -->
    <TextView
        android:id="@+id/tvQrProfileData"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp"
        android:background="@drawable/bg_card"
        android:fontFamily="monospace"
        android:gravity="center"
        android:padding="12dp"
        android:text=""
        android:textColor="@color/colorTextMuted"
        android:textSize="12sp" />

    <!-- Share QR Image button -->
    <Button
        android:id="@+id/btnShareQrImage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="10dp"
        android:background="@drawable/btn_green_gradient"
        android:drawableStart="@drawable/ic_share"
        android:drawablePadding="8dp"
        android:enabled="false"
        android:paddingTop="14dp"
        android:paddingBottom="14dp"
        android:text="Share QR Code Image"
        android:textAllCaps="false"
        android:textColor="@color/colorBackground"
        android:textSize="15sp"
        android:textStyle="bold"
        android:contentDescription="Share QR code image" />

    <!-- Share as text button -->
    <Button
        android:id="@+id/btnShareText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="10dp"
        android:background="@drawable/btn_secondary"
        android:paddingTop="14dp"
        android:paddingBottom="14dp"
        android:text="Share as Text"
        android:textAllCaps="false"
        android:textColor="@color/colorPrimary"
        android:textSize="15sp"
        android:contentDescription="Share profile as plain text" />

    <Button
        android:id="@+id/btnCloseDialog"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:text="Close"
        android:textAllCaps="false"
        android:textColor="@color/colorTextMuted"
        android:textSize="14sp"
        android:contentDescription="Close dialog" />

</LinearLayout>
