<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingBottom="12dp">

    <TextView
        android:id="@+id/tvQuestionNumber"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="1. Question text here"
        android:textColor="@color/colorTextPrimary"
        android:textSize="14sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <!-- Answer option: user's answer (red = wrong, green = correct) -->
    <LinearLayout
        android:id="@+id/rowUserAnswer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="4dp">

        <View
            android:id="@+id/dotUserAnswer"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="@drawable/shape_dot_red" />

        <TextView
            android:id="@+id/tvUserAnswer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="User answer"
            android:textColor="@color/colorTextPrimary"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tvUserAnswerLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Your Answer"
            android:textColor="@color/colorError"
            android:textSize="11sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Answer option: correct answer (green) -->
    <LinearLayout
        android:id="@+id/rowCorrectAnswer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="4dp">

        <View
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="@drawable/shape_dot_green" />

        <TextView
            android:id="@+id/tvCorrectAnswer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="Correct answer"
            android:textColor="@color/colorTextPrimary"
            android:textSize="13sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Correct Answer"
            android:textColor="@color/colorSuccess"
            android:textSize="11sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Answer option: other option (grey) -->
    <LinearLayout
        android:id="@+id/rowOtherAnswer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <View
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="@drawable/shape_dot_grey" />

        <TextView
            android:id="@+id/tvOtherAnswer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="Other option"
            android:textColor="@color/colorTextMuted"
            android:textSize="13sp" />
    </LinearLayout>

</LinearLayout>
